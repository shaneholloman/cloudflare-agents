{
  "name": "@cloudflare/agents-repo",
  "description": "The monorepo for Cloudflare Agents and related work",
  "type": "module",
  "keywords": [
    "cloudflare",
    "workers",
    "ai",
    "agents",
    "durable objects",
    "workflows"
  ],
  "author": "Cloudflare Agents <1800-agents@cloudflare.com>",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "typecheck": "npx tsx scripts/typecheck.ts",
    "check:exports": "npx tsx scripts/check-exports.ts",
    "check": "sherif && npm run check:exports && oxfmt --check . && oxlint . && npm run typecheck",
    "test": "nx run-many -t test",
    "ci": "oxfmt --write . && nx run-many -t build test && npm run check",
    "test:e2e": "nx run-many -t test:e2e",
    "test:react": "npm run test:react -w agents",
    "postinstall": "patch-package",
    "prepare:playwright": "playwright install --with-deps chromium",
    "prepare": "husky"
  },
  "license": "MIT",
  "version": "0.0.0",
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/google": "^3.0.67",
    "@ai-sdk/openai": "^3.0.58",
    "@ai-sdk/react": "^3.0.176",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@cloudflare/kumo": "^2.0.2",
    "@cloudflare/vite-plugin": "^1.35.0",
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260501.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@openai/agents": "^0.8.5",
    "@openai/agents-extensions": "^0.8.5",
    "@phosphor-icons/react": "^2.1.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/runner": "^4.1.5",
    "ai": "^6.0.174",
    "autoevals": "^0.0.132",
    "concurrently": "^9.2.1",
    "evalite": "^0.19.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nx": "^22.7.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "partyserver": "^0.5.6",
    "partysocket": "1.1.19",
    "patch-package": "^8.0.1",
    "pkg-pr-new": "^0.0.69",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sherif": "^1.11.1",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "4.1.5",
    "vitest-browser-react": "^2.2.0",
    "workers-ai-provider": "^3.1.13",
    "wrangler": "^4.87.0",
    "zod": "^4.4.2"
  },
  "workspaces": [
    "examples/*",
    "packages/*",
    "voice-providers/*",
    "guides/*",
    "experimental/*",
    "openai-sdk/*",
    "site/*"
  ],
  "overrides": {
    "esbuild": "^0.25.1"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,astro,svelte,css}": [
      "oxfmt --write"
    ]
  },
  "packageManager": "npm@11.13.0"
}
